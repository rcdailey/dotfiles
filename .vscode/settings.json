{
  "files.associations": {
    "*gitconfig.tmpl": "properties",
    ".chezmoiignore": "ignore",
    "*.sh.tmpl": "shellscript",
    "*.toml.tmpl": "toml",
    "*.yaml.tmpl": "yaml",
    "*.yml.tmpl": "yaml",
    "*.ps1.tmpl": "powershell",
    "*.md.tmpl": "markdown",
    "*_config": "ssh_config",
    "Brewfile.tmpl": "ruby",
    "*zshenv.tmpl": "shellscript",
    "*.jsonc.tmpl": "jsonc"
  },
  "[yaml]": {
    "editor.defaultFormatter": "kennylong.kubernetes-yaml-formatter"
  }
}
