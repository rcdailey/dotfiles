#!/usr/bin/env zsh
# Tear down a dispatched ticket: close kitty tab, remove worktree, delete branch.
# Usage: dispatch-done <TICKET-ID>    e.g. dispatch-done ENG-123

local ticket_id="${1:?Usage: dispatch-done <TICKET-ID>}"
local repo_root
repo_root=$(git rev-parse --show-toplevel) || return 1

local repo_name="${repo_root:t}"
local branch_name="${ticket_id:l}"
local worktree_path="${repo_root:h}/${repo_name}-${branch_name}"

kitty @ close-tab --match "title:^${ticket_id}$" 2>/dev/null || true
git worktree remove --force "$worktree_path" 2>/dev/null || true
git branch -D "$branch_name" 2>/dev/null || true
