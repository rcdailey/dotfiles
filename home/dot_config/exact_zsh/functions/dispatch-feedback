#!/usr/bin/env zsh
# Trigger a pr-feedback iteration for a dispatched ticket in its kitty tab.
# Usage: dispatch-feedback <TICKET-ID> [PR-NUMBER]    e.g. dispatch-feedback ENG-123
# PR number defaults to the PR for the worktree's branch (gh pr view).

local ticket_id="${1:?Usage: dispatch-feedback <TICKET-ID> [PR-NUMBER]}"
local pr_number="$2"
local repo_root
repo_root=$(git rev-parse --show-toplevel) || return 1

local repo_name="${repo_root:t}"
local branch_name="${ticket_id:l}"
local worktree_path="${repo_root:h}/${repo_name}-${branch_name}"

if [[ ! -d "$worktree_path" ]]; then
  print -u2 "dispatch-feedback: worktree not found: $worktree_path"
  return 1
fi

if [[ -z "$pr_number" ]]; then
  pr_number=$(cd "$worktree_path" && gh pr view --json number -q .number) || {
    print -u2 "dispatch-feedback: no PR found for branch $branch_name"
    return 1
  }
fi

local run_cmd="opencode run --command pr-feedback $pr_number"
if kitty @ ls 2>/dev/null | jq -e --arg t "$ticket_id" \
  '[.[].tabs[] | select(.title == $t)] | length > 0' >/dev/null 2>&1; then
  kitty @ send-text --match "title:^${ticket_id}$" "$run_cmd\n"
else
  kitty @ launch --type=tab --tab-title "$ticket_id" --keep-focus \
    --cwd="$worktree_path" --env OPENCODE_DISPATCH=1 \
    sh -c "$run_cmd; exec zsh"
fi
