# Ignore patterns for Claude Code's @-file auto complete behavior. These ignore patterns normally
# shouldn't be necessary, however they are needed to hide certain paths from the auto completion
# list.
.git/

# Ignore claude local files
settings.local.json
CLAUDE.local.md

# Convention for 'temp' ignored files and directories living in repos
*.ignored.*
*.ignored/

# Ignore repo-level mise configuration by default. Most of the time these are for local tooling
# management, not really for team sharing. For exceptions to this, we can use `git add -f`.
*.local.toml

# 04/03/2026: Bug in opencode 1.3.15 that introduced package-lock.json but never added it to the
# auto-generated `.opencode/.gitignore`.
/.opencode/package-lock.json
