# Kitty Terminal Configuration

# Remote control for scripting (dispatch functions, reload-all alias)
allow_remote_control yes
listen_on unix:/tmp/kitty-{kitty_pid}

# macOS: treat Option as Alt for keybindings (ignored on Linux)
macos_option_as_alt yes

# Font settings
font_family postscript_name=FiraCode-Regular
bold_font postscript_name=FiraCode-Bold
italic_font auto
bold_italic_font auto
font_size {{ .terminal.fontSize }}

# Window management
confirm_os_window_close 0
remember_window_size no
initial_window_width 872
initial_window_height 782
remember_window_position yes

copy_on_select clipboard
enable_audio_bell no
inactive_text_alpha 0.7
mouse_hide_wait 3.0
window_padding_width 2
scrollback_lines 50000

# Splits and pane borders
enabled_layouts splits:equalize_on_close=true,stack
active_border_color #ff79c6
inactive_border_color #44475a

# Tab bar (Dracula theme)
tab_bar_style powerline
tab_title_template "{index}: {title}"
active_tab_foreground #282a36
active_tab_background #ff79c6
active_tab_font_style bold
inactive_tab_foreground #f8f8f2
inactive_tab_background #282a36

#
# Keybindings
#

# Splits
map ctrl+shift+e launch --location=hsplit --cwd=current
map ctrl+shift+o launch --location=vsplit --cwd=current

# Navigate panes
map ctrl+shift+left neighboring_window left
map ctrl+shift+right neighboring_window right
map ctrl+shift+up neighboring_window up
map ctrl+shift+down neighboring_window down

# Close pane
map ctrl+shift+w close_window

# Swap pane
map alt+shift+s swap_with_window

# Tabs
map ctrl+shift+t new_tab_with_cwd
map ctrl+page_up previous_tab
map ctrl+page_down next_tab
map f2 set_tab_title

# Zoom (toggle between splits and stack layouts)
map ctrl+shift+z toggle_layout stack

# Resize panes
map ctrl+alt+left resize_window narrower 2
map ctrl+alt+right resize_window wider 2
map ctrl+alt+up resize_window taller 2
map ctrl+alt+down resize_window shorter 2

# Reload config
map ctrl+shift+, load_config_file

# New OS window
map ctrl+shift+n new_os_window_with_cwd

# Insert newline without executing
map shift+enter send_text all \n
