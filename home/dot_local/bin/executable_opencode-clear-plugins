#!/usr/bin/env bash

# opencode-clear-plugins - Clear cached @latest opencode plugins
#
# Opencode caches each plugin in its own directory under
# $XDG_CACHE_HOME/opencode/packages/<spec>/ via @npmcli/arborist. Once a
# tree exists there, Npm.add() short-circuits via loadVirtual() and never
# re-checks the registry, so @latest-tagged plugins stay pinned to whatever
# was first resolved. Removing the per-spec directory is the only way to
# force a fresh resolve on next launch.
#
# This only touches directories whose basename ends in "@latest" (both
# unscoped like "pkg@latest" and scoped like "@scope/pkg@latest"). Pinned
# versions and non-plugin entries (e.g. pyright LSP) are left alone.
#
# Usage:
#   opencode-clear-plugins

set -euo pipefail

readonly CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/opencode"
readonly PACKAGES_DIR="$CACHE_DIR/packages"

if [[ ! -d "$PACKAGES_DIR" ]]; then
  echo "No opencode package cache at $PACKAGES_DIR"
  exit 0
fi

removed=0

remove_dir() {
  local target="$1"
  rm -rf "$target"
  echo "Removed $target"
  ((++removed))
}

# Unscoped: <pkg>@latest
shopt -s nullglob
for dir in "$PACKAGES_DIR"/*@latest; do
  [[ -d "$dir" ]] && remove_dir "$dir"
done

# Scoped: @scope/<pkg>@latest
for dir in "$PACKAGES_DIR"/@*/*@latest; do
  [[ -d "$dir" ]] && remove_dir "$dir"
done
shopt -u nullglob

if ((removed == 0)); then
  echo "No @latest plugins cached."
else
  echo "Cleared $removed plugin(s). They'll re-resolve on next opencode launch."
fi
