#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "markitdown[all]",
#     "ocrmypdf",
# ]
# ///
"""pdf2md - convert PDFs (local files or URLs) to markdown.

Downloads (if URL), optionally OCRs, and converts a PDF to markdown
using markitdown. OCR is lazy by default: only runs when the PDF has
little or no extractable text.

Usage:
    pdf2md FILE_OR_URL [OPTIONS]

Options:
    --force-ocr        always run OCR regardless of text detection
    --ocr-inplace      write OCR result back to the source file
                       (local files only)
    --page-size N      characters per page of output (default: 20000)
    --page N           which page of output to return (default: 1)
    --find PATTERN     search output by paragraph (regex or literal)
    -C, --context N    paragraphs of context around --find matches
                       (default: 1)
"""

from __future__ import annotations

import argparse
import math
import os
import re
import sys
import tempfile
import urllib.request

# Characters-per-PDF-page threshold. If average extractable text per
# page falls below this, the PDF is considered scanned and needs OCR.
OCR_THRESHOLD = 100


def _is_url(source: str) -> bool:
    return source.startswith("http://") or source.startswith("https://")


def _download(url: str, dest: str) -> None:
    req = urllib.request.Request(
        url, headers={"User-Agent": "pdf2md/1.0"}
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        with open(dest, "wb") as f:
            while True:
                chunk = resp.read(65536)
                if not chunk:
                    break
                f.write(chunk)


def _needs_ocr(pdf_path: str) -> bool:
    """Check if a PDF needs OCR by measuring extractable text density."""
    from pdfminer.high_level import extract_text
    from pdfminer.pdfpage import PDFPage

    try:
        with open(pdf_path, "rb") as f:
            page_count = sum(1 for _ in PDFPage.get_pages(f))
        if page_count == 0:
            return True
        text = extract_text(pdf_path)
        chars = len(text.strip())
        avg_per_page = chars / page_count
        return avg_per_page < OCR_THRESHOLD
    except Exception:
        # If we can't determine, assume OCR is needed
        return True


def _run_ocr(
    input_path: str, output_path: str, *, force: bool = False
) -> str:
    """Run ocrmypdf. Returns path to the OCR'd PDF."""
    import ocrmypdf

    kwargs = {"progress_bar": False}
    if force:
        kwargs["redo_ocr"] = True
    else:
        kwargs["skip_text"] = True

    try:
        ocrmypdf.ocr(input_path, output_path, **kwargs)
        return output_path
    except ocrmypdf.PriorOcrFoundError:
        return input_path
    except ocrmypdf.exceptions.ExitCodeException as e:
        print(
            f"warning: ocrmypdf failed ({e}), falling back to original",
            file=sys.stderr,
        )
        return input_path


def _convert_to_markdown(pdf_path: str) -> str:
    """Convert a PDF to markdown using markitdown."""
    from markitdown import MarkItDown

    converter = MarkItDown()
    result = converter.convert(pdf_path)
    return result.text_content


def _paragraph_find(text: str, pattern: str, context: int) -> str:
    """Search text by paragraph, returning matches with context."""
    paragraphs = re.split(r"\n{2,}", text)
    matches: list[int] = []
    try:
        regex = re.compile(pattern, re.IGNORECASE)
    except re.error:
        regex = re.compile(re.escape(pattern), re.IGNORECASE)
    for i, para in enumerate(paragraphs):
        if regex.search(para):
            matches.append(i)
    if not matches:
        return f"No matches for: {pattern}"
    seen: set[int] = set()
    result_parts: list[str] = []
    for idx in matches:
        start = max(0, idx - context)
        end = min(len(paragraphs), idx + context + 1)
        for i in range(start, end):
            if i not in seen:
                seen.add(i)
                result_parts.append(paragraphs[i])
        result_parts.append("---")
    return "\n\n".join(result_parts).rstrip("\n-")


def _paginate(text: str, page_size: int, page: int) -> str:
    """Return a specific page of text with a pagination footer."""
    total_chars = len(text)
    total_pages = max(1, math.ceil(total_chars / page_size))

    if page < 1 or page > total_pages:
        return (
            f"error: page {page} out of range "
            f"(1-{total_pages} available)"
        )

    start = (page - 1) * page_size
    end = start + page_size
    chunk = text[start:end]

    footer = f"\n\n[page {page}/{total_pages}, {page_size} chars/page]"
    if page < total_pages:
        footer += f"\n[use --page {page + 1} for next page]"
    return chunk + footer


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="pdf2md",
        description="Convert a PDF (local file or URL) to markdown.",
    )
    parser.add_argument("source", help="local file path or URL")
    parser.add_argument(
        "--force-ocr", action="store_true",
        help="always run OCR regardless of text detection",
    )
    parser.add_argument(
        "--ocr-inplace", action="store_true",
        help="write OCR result back to the source file (local only)",
    )
    parser.add_argument(
        "--page-size", type=int, default=20000,
        help="characters per page of output (default: 20000)",
    )
    parser.add_argument(
        "--page", type=int, default=1,
        help="which page of output to return (default: 1)",
    )
    parser.add_argument(
        "--find", default=None,
        help="search output by paragraph (regex or literal)",
    )
    parser.add_argument(
        "-C", "--context", type=int, default=1,
        help="paragraphs of context around --find matches (default: 1)",
    )
    opts = parser.parse_args()

    is_url = _is_url(opts.source)

    if opts.ocr_inplace and is_url:
        parser.error("--ocr-inplace cannot be used with URLs")

    tmpdir = tempfile.mkdtemp(prefix="pdf2md-")
    tmp_files: list[str] = []

    try:
        # Resolve source to a local file
        if is_url:
            pdf_path = os.path.join(tmpdir, "input.pdf")
            tmp_files.append(pdf_path)
            try:
                _download(opts.source, pdf_path)
            except Exception as e:
                print(f"error: download failed: {e}", file=sys.stderr)
                sys.exit(1)
        else:
            pdf_path = os.path.abspath(opts.source)
            if not os.path.isfile(pdf_path):
                print(
                    f"error: file not found: {opts.source}",
                    file=sys.stderr,
                )
                sys.exit(1)

        # OCR decision
        do_ocr = opts.force_ocr or _needs_ocr(pdf_path)

        if do_ocr:
            if opts.ocr_inplace:
                ocr_out = pdf_path
            else:
                ocr_out = os.path.join(tmpdir, "ocr.pdf")
                tmp_files.append(ocr_out)

            pdf_path = _run_ocr(
                pdf_path, ocr_out, force=opts.force_ocr
            )

        # Convert
        output = _convert_to_markdown(pdf_path)

        # Apply --find if requested
        if opts.find:
            output = _paragraph_find(
                output, opts.find, opts.context
            )

        # Paginate
        output = _paginate(output, opts.page_size, opts.page)

        print(output)

    finally:
        for f in tmp_files:
            try:
                os.unlink(f)
            except OSError:
                pass
        try:
            os.rmdir(tmpdir)
        except OSError:
            pass


if __name__ == "__main__":
    main()
