#!/usr/bin/env bash
# Serializing pinentry wrapper. rbw-agent spawns concurrent pinentry processes
# when multiple SSH operations trigger unlock simultaneously. This wrapper uses
# flock so only one pinentry dialog appears; others block until it completes.

{{- if eq .chezmoi.os "darwin" }}
PINENTRY=/usr/local/bin/pinentry-mac
{{- else }}
PINENTRY=/usr/bin/pinentry-qt
{{- end }}

LOCK_DIR="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}"
exec flock "$LOCK_DIR/pinentry-serialized.lock" "$PINENTRY" "$@"
