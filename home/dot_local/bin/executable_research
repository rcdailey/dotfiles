#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""research - budget-enforced wrapper for researcher agent tools.

Tracks tool call count across a research session and enforces a hard
budget.  A session starts on the first call and auto-resets after 30
seconds of inactivity (gap between consecutive calls).

Usage:
    research scout ARGS...    # delegates to gh-scout
    research web ARGS...      # delegates to web
    research gh ARGS...       # delegates to gh
    research pdf ARGS...      # delegates to pdf2md
    research status           # print current budget usage

Budget messages print to stdout so they cannot be suppressed with
2>/dev/null.  They appear after the tool output completes.

File locking (fcntl.flock) ensures parallel calls each get a unique
counter value.
"""

from __future__ import annotations

import fcntl
import json
import subprocess
import sys
import time
from typing import NoReturn

BUDGET_FILE = "/tmp/.research-budget"
LOCK_FILE = "/tmp/.research-budget.lock"
MAX_CALLS = 15
CHECKPOINT_AT = MAX_CALLS // 2       # mid-session assessment prompt
WARNING_AT = MAX_CALLS - 3           # final warning before cutoff
IDLE_TIMEOUT = 30  # seconds between calls before session resets

TOOL_MAP = {
    "scout": "gh-scout",
    "web": "web",
    "gh": "gh",
    "pdf": "pdf2md",
}

USAGE = (
    "usage: research {scout|web|gh|pdf} ARGS...\n"
    "       research status\n"
    "\n"
    "Budget-enforced wrapper for researcher agent tools.\n"
    f"Tracks tool call count and enforces a hard {MAX_CALLS}-call limit.\n"
    "\n"
    "subcommands:\n"
    "  scout ARGS...    delegates to gh-scout\n"
    "  web ARGS...      delegates to web\n"
    "  gh ARGS...       delegates to gh\n"
    "  pdf ARGS...      delegates to pdf2md\n"
    "  status           print current budget usage"
)


def die(message: str) -> NoReturn:
    print(USAGE, file=sys.stderr)
    print(f"\nerror: {message}", file=sys.stderr)
    sys.exit(2)


def _read_state_unlocked() -> tuple[float, int, set[str]]:
    """Read state without locking. Caller must hold the lock."""
    try:
        with open(BUDGET_FILE) as f:
            data = json.load(f)
            last_ts = float(data["ts"])
            count = int(data["count"])
            urls = set(data.get("urls", []))
            if time.time() - last_ts > IDLE_TIMEOUT:
                return (0.0, 0, set())
            return (last_ts, count, urls)
    except (FileNotFoundError, ValueError, KeyError, json.JSONDecodeError):
        return (0.0, 0, set())


def _write_state_unlocked(count: int, urls: set[str]) -> None:
    """Write state without locking. Caller must hold the lock."""
    with open(BUDGET_FILE, "w") as f:
        json.dump(
            {"ts": time.time(), "count": count, "urls": sorted(urls)},
            f,
        )


def _budget_message(count: int) -> str:
    """Return a budget message for the current call count."""
    remaining = MAX_CALLS - count
    counter = f"[budget: {count}/{MAX_CALLS} calls used, {remaining} remaining]"

    if remaining < 0:
        return (
            f"\n=== BUDGET EXCEEDED ({MAX_CALLS}/{MAX_CALLS} calls used) ===\n"
            "You MUST synthesize your answer NOW from what you have gathered.\n"
            "No more tool calls will be executed."
        )
    if count == CHECKPOINT_AT:
        return (
            f"\n=== CHECKPOINT: {count}/{MAX_CALLS} calls used, "
            f"{remaining} remaining ===\n"
            "Stop and assess: can you answer the question now?\n"
            "If yes, synthesize. If not, identify the ONE specific "
            "gap that remains."
        )
    if count == WARNING_AT:
        return (
            f"\n=== WARNING: {count}/{MAX_CALLS} calls used, "
            f"{remaining} remaining ===\n"
            "Begin synthesizing your answer NOW. Use remaining calls "
            "only for critical gaps."
        )
    return f"\n{counter}"


def _budget_check_and_print(cached_url: str | None = None) -> int:
    """Atomically increment counter and print the budget message.

    If cached_url is provided and was already seen this session, the
    call is free (no budget slot consumed). The URL is recorded so
    the first fetch costs a slot and subsequent --find variations
    are free.

    The print happens while the lock is held so that parallel callers
    see their counter values in the order they finished, not in
    whatever order the OS schedules their post-lock prints.
    """
    with open(LOCK_FILE, "w") as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)
        _, count, urls = _read_state_unlocked()

        if cached_url and cached_url in urls:
            # Already fetched this URL; free pass
            _write_state_unlocked(count, urls)
            remaining = MAX_CALLS - count
            print(
                f"\n[cached: {remaining} calls remaining]",
                flush=True,
            )
            return count

        if cached_url:
            urls.add(cached_url)

        count += 1
        _write_state_unlocked(count, urls)
        print(_budget_message(count), flush=True)
        remaining = MAX_CALLS - count
        if remaining < 0:
            sys.exit(1)
        # Lock released when 'lock' file handle is closed

    return count


def cmd_status() -> None:
    with open(LOCK_FILE, "w") as lock:
        fcntl.flock(lock, fcntl.LOCK_SH)
        _, count, urls = _read_state_unlocked()
    remaining = MAX_CALLS - count
    print(f"{count}/{MAX_CALLS} calls used, {remaining} remaining")
    if urls:
        print(f"cached URLs: {len(urls)}")


def _extract_cacheable_url(tool: str, args: list[str]) -> str | None:
    """Extract the base URL for cache tracking.

    Returns the URL for commands that operate on a fetchable resource
    (web fetch, pdf). Returns None for commands where URL caching
    does not apply (web search, scout, gh).
    """
    if tool == "pdf" and args:
        return args[0].split("?")[0]
    if tool == "web" and len(args) >= 2 and args[0] == "fetch":
        return args[1].split("?")[0]
    return None


def main() -> None:
    if len(sys.argv) < 2:
        die("no subcommand provided")

    tool = sys.argv[1]

    if tool == "status":
        cmd_status()
        return

    if tool not in TOOL_MAP:
        die(f"unknown subcommand '{tool}'")

    tool_args = sys.argv[2:]
    cmd = [TOOL_MAP[tool]] + tool_args
    try:
        result = subprocess.run(cmd)
    except FileNotFoundError:
        die(f"command not found: {TOOL_MAP[tool]}")
    except KeyboardInterrupt:
        sys.exit(130)

    # Usage errors (exit code 2) mean no real work was done; don't
    # burn a budget slot for a malformed command.
    if result.returncode == 2:
        sys.exit(2)

    # Budget message prints to stdout (inside the lock) so it cannot
    # be suppressed by 2>/dev/null on the command line and so parallel
    # callers see counter values in completion order.
    cached_url = _extract_cacheable_url(tool, tool_args)
    _budget_check_and_print(cached_url)

    sys.exit(result.returncode)


if __name__ == "__main__":
    main()
