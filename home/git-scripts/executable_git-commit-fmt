#!/usr/bin/env python3
"""Structured commit message formatter for LLM-driven workflows.

Accepts a subject line, optional body paragraphs, changelog entries, and
issue references as separate arguments. Enforces commit message structure
and handles all text wrapping, then calls git commit.
"""

import argparse
import os
import subprocess
import sys
import tempfile
import textwrap

SUBJECT_WIDTH = int(os.environ.get("GIT_COMMIT_FMT_SUBJECT_WIDTH", 50))
BODY_WIDTH = int(os.environ.get("GIT_COMMIT_FMT_BODY_WIDTH", 72))


def wrap_paragraph(text):
    """Wrap a plain-text paragraph to BODY_WIDTH."""
    return textwrap.fill(text.strip(), width=BODY_WIDTH)


def wrap_changelog(text):
    """Wrap a changelog entry as a bullet item with continuation indent."""
    prefix = "- "
    continuation = "  "
    return textwrap.fill(
        text.strip(),
        width=BODY_WIDTH,
        initial_indent=prefix,
        subsequent_indent=continuation,
    )


def format_message(subject, paragraphs, changelogs, issues):
    """Assemble the full commit message in enforced structural order."""
    parts = [subject]

    body_sections = []

    if paragraphs:
        body_sections.append(
            "\n\n".join(wrap_paragraph(p) for p in paragraphs)
        )

    if changelogs:
        body_sections.append(
            "\n".join(wrap_changelog(c) for c in changelogs)
        )

    if issues:
        body_sections.append("\n".join(i.strip() for i in issues))

    if body_sections:
        parts.append("")
        parts.append("\n\n".join(body_sections))

    return "\n".join(parts) + "\n"


def main():
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("-s", required=True)
    parser.add_argument("-p", action="append", default=[])
    parser.add_argument("-c", action="append", default=[])
    parser.add_argument("-i", action="append", default=[])
    parser.add_argument("-n", action="store_true")
    args = parser.parse_args()

    subject = args.s.strip()
    if len(subject) > SUBJECT_WIDTH:
        print(
            f"error: subject is {len(subject)} chars, exceeds"
            f" {SUBJECT_WIDTH}-char limit",
            file=sys.stderr,
        )
        sys.exit(1)

    message = format_message(subject, args.p, args.c, args.i)

    if args.n:
        print(message, end="")
        sys.exit(0)

    fd, msg_path = tempfile.mkstemp(prefix="commit-msg-", suffix=".txt")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(message)

        result = subprocess.run(["git", "commit", "-F", msg_path])
        sys.exit(result.returncode)
    finally:
        os.unlink(msg_path)


if __name__ == "__main__":
    main()
